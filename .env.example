# Slack — see README.md for how to obtain these
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Backend: "claude-code" (uses your Claude subscription, no API key needed)
#          "messages"    (uses Anthropic API, requires ANTHROPIC_API_KEY)
#          "managed"     (uses Managed Agents API beta, requires ANTHROPIC_API_KEY + AGENT_ID)
DEFAULT_BACKEND=claude-code

# Model: "sonnet", "opus", "haiku", or a full model ID like "claude-sonnet-4-6"
DEFAULT_MODEL=sonnet

# Anthropic API key (only needed for "messages" or "managed" backends)
ANTHROPIC_API_KEY=

# Managed Agents (only needed for "managed" backend — run `python -m scripts.create_agent`)
AGENT_ID=
AGENT_VERSION=1

# Database
DB_PATH=data/claude_slack_bot.db

# Behaviour
SUMMARY_INTERVAL_TURNS=5
CONFIRMATION_TIMEOUT_SECONDS=300

# Media (optional — for external image generation API)
IMAGE_API_URL=
IMAGE_API_KEY=

# Logging
LOG_LEVEL=INFO
