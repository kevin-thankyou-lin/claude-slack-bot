# Slack — see README.md for how to obtain these
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Managed Agents (optional — run `python -m scripts.create_agent` to generate these)
AGENT_ID=
AGENT_VERSION=1

# Behaviour
DEFAULT_BACKEND=messages        # "managed" or "messages"
DEFAULT_MODEL=claude-sonnet-4-6
DB_PATH=data/claude_slack_bot.db
SUMMARY_INTERVAL_TURNS=5
CONFIRMATION_TIMEOUT_SECONDS=300

# Media (optional — for external image generation API)
IMAGE_API_URL=
IMAGE_API_KEY=

# Logging
LOG_LEVEL=INFO
